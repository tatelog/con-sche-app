# フロントエンドのビルド時環境変数（VITE_ プレフィックスのみバンドルに埋め込まれる）
#
# 本番ビルド用は .env.production に書く（.env.local より優先される）。
# .env.production / .env.local はコミットしないこと。

# 登録・問い合わせ・連携APIの接続先（Cloudflare Workers のURL）。
# 未設定時は同一オリジンの /api を使用します（開発時は vite の proxy 経由で localhost:8787 へ）。
# VITE_API_BASE=https://your-worker.example.workers.dev

# 登録ゲートのスキップ（登録APIを立てていない環境でのプレビュー用。本番では必ず false）
# VITE_SKIP_REGISTRATION=true
